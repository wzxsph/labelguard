# Default is deterministic and does not call an external model.
LABELGUARD_AI_MODE=mock

# Optional server-only OpenAI-compatible endpoint. Never prefix these with VITE_.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
# LabelGuard remote acceptance is locked to MiniMax-M3 in server code.
PORT=4176
